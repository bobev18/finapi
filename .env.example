# Client API key used to access public endpoints on Service A
CLIENT_API_KEY=your_client_api_key_here

# Internal API key used for communication from Service A to Service B (and Service C to Service B)
INTERNAL_API_KEY=your_internal_api_key_here

# Cache duration (in seconds) for external market data requests in Service B
CACHE_TTL_SECONDS=300

# Base URL for Service B (Market Data Service)
SERVICE_B_URL=http://localhost:8001

# Base URL for Service C (Market Signal Service)
SERVICE_C_URL=http://localhost:8002

# Internal API key used for communication from Service A to Service C
SIGNAL_API_KEY=your_signal_api_key_here
